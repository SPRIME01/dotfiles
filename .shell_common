export ProjectsHome="/c/Users/sprim/Projects"

alias projects='cd "$ProjectsHome"'
alias dotfiles='git --git-dir=$HOME/dotfiles/.git --work-tree=$HOME'

if command -v code >/dev/null; then
  alias pcode='code -n "$ProjectsHome" --disable-extensions"'
fi

if [ -n "$BASH_VERSION" ]; then
  echo "👋 Welcome back, Bash commander."
elif [ -n "$ZSH_VERSION" ]; then
  echo "✨ All hail the Zsh wizard."
fi

case "$(hostname)" in
  workstation-name)
    export SPECIAL_VAR="true"
    echo "🔒 Loaded workstation-specific config"
    ;;
  dev-laptop)
    export SPECIAL_VAR="false"
    echo "🔒 Loaded dev laptop config"
    ;;
esac
